cat <<EOT > .gitignore
# --- C++ Build Artifacts ---
bin/
*.o
*.d
loadbal_sim
main  # In case you compiled without -o

# --- Python Environment & Cache ---
venv/
__pycache__/
*.pyc

# --- Data Directories ---
data/


# --- Output/Results Directories ---
.png

# --- Large Data Files (In case they are in root) ---
*.csv
*.dat
*.parquet
*.gz
*.zip
*.json


# --- OS & Editor Configs ---
.DS_Store
.vscode/
.idea/

# --- Specific Scripts to Ignore (As requested) ---
scripts/process_*.py

EOT